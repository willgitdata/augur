{
  "name": "@augur-rag/server",
  "version": "0.1.0",
  "description": "Augur HTTP API server. Drop-in Fastify wrapper around @augur-rag/core with OpenAPI docs and trace explorer compatibility.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "augur-server": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "augur",
    "rag",
    "retrieval",
    "fastify",
    "http-api",
    "openapi"
  ],
  "homepage": "https://github.com/willgitdata/augur#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/willgitdata/augur.git",
    "directory": "packages/server"
  },
  "bugs": {
    "url": "https://github.com/willgitdata/augur/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm clean && pnpm build && pnpm typecheck"
  },
  "dependencies": {
    "@augur-rag/core": "workspace:*",
    "fastify": "^5.8.5",
    "@fastify/cors": "^11.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
