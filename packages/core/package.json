{
  "name": "@augur-rag/core",
  "version": "0.1.1",
  "description": "Adaptive retrieval orchestration for RAG and semantic search in TypeScript: per-query routing across vector / BM25 / hybrid + cross-encoder reranking, with full traces. Works with pgvector, Pinecone, Turbopuffer, or any custom adapter.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    },
    "./chunking": {
      "types": "./dist/chunking/index.d.ts",
      "import": "./dist/chunking/index.js"
    },
    "./routing": {
      "types": "./dist/routing/index.d.ts",
      "import": "./dist/routing/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "rag",
    "rag-pipeline",
    "retrieval-augmented-generation",
    "retrieval",
    "vector-search",
    "vector-retrieval",
    "semantic-search",
    "bm25",
    "hybrid-search",
    "reranking",
    "cross-encoder",
    "embeddings",
    "sentence-transformers",
    "contextual-retrieval",
    "pgvector",
    "pinecone",
    "turbopuffer",
    "onnx",
    "huggingface",
    "typescript",
    "ai",
    "llm",
    "mteb",
    "beir",
    "nlp",
    "information-retrieval"
  ],
  "homepage": "https://github.com/willgitdata/augur#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/willgitdata/augur.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/willgitdata/augur/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "find src -name '*.test.ts' -print0 | xargs -0 node --test --import tsx",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepublishOnly": "pnpm clean && pnpm build && pnpm test"
  },
  "peerDependencies": {
    "@huggingface/transformers": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@huggingface/transformers": {
      "optional": true
    }
  },
  "devDependencies": {
    "@huggingface/transformers": "4.2.0",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
